    <sys:String x:Key="CopyTooltip" xmlns:sys="clr-namespace:System;assembly=mscorlib">Click the message bubble to copy its text.</sys:String>
    <sys:String x:Key="EmptyChatState" xmlns:sys="clr-namespace:System;assembly=mscorlib">No messages yet. Connect to a local peer to start chatting.</sys:String>
