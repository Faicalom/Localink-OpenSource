    <sys:String x:Key="SelectDevicePrompt" xmlns:sys="clr-namespace:System;assembly=mscorlib">Select a device to connect</sys:String>
    <sys:String x:Key="PairingHintText" xmlns:sys="clr-namespace:System;assembly=mscorlib">Enter the code shown on the selected device only when this PC starts the session. If the phone starts the Bluetooth session, keep this PC open and enter this PC's code on Android instead. Bluetooth is slower than local Wi-Fi and is best for chat plus files up to 300 MB.</sys:String>
    <sys:String x:Key="YourPairingCodeLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Your pairing code:</sys:String>
