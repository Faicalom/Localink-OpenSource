    <sys:String x:Key="HistoryTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">History</sys:String>
    <sys:String x:Key="HistoryHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">These buttons clear local history records only. Saved files already written to disk stay in your download folder.</sys:String>
    <sys:String x:Key="ClearChatHistoryButton" xmlns:sys="clr-namespace:System;assembly=mscorlib">Clear Chat History</sys:String>
    <sys:String x:Key="ClearTransferHistoryButton" xmlns:sys="clr-namespace:System;assembly=mscorlib">Clear Transfer History</sys:String>
