    <sys:String x:Key="SettingsTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Settings</sys:String>
    <sys:String x:Key="PreferredModeLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Preferred connection mode</sys:String>
    <sys:String x:Key="PreferredModeHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Auto prefers hotspot/LAN first. Bluetooth stays available as a slower fallback mainly for messages.</sys:String>
    <sys:String x:Key="LanguageLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">App language</sys:String>
    <sys:String x:Key="LanguageHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Choose the desktop UI language. Logs and low-level protocol diagnostics remain in English.</sys:String>
    <sys:String x:Key="DownloadFolderLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Download folder</sys:String>
    <sys:String x:Key="DownloadFolderHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Received files are saved to this folder when a transfer completes.</sys:String>
    <sys:String x:Key="TransferSizeNoteLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Transfer size note</sys:String>
    <sys:String x:Key="TransferSizeNoteText" xmlns:sys="clr-namespace:System;assembly=mscorlib">This build now supports files up to 20 GB per transfer over hotspot/LAN. Practical speed and stability still depend on storage performance, cable-free signal quality, and how stable the local route stays during long transfers.</sys:String>
    <sys:String x:Key="AutoDiscoveryCheckbox" xmlns:sys="clr-namespace:System;assembly=mscorlib">Auto-start discovery on launch</sys:String>
    <sys:String x:Key="RouteSensorTitle" xmlns:sys="clr-namespace:System;assembly=mscorlib">Network route sensor</sys:String>
    <sys:String x:Key="RouteSensorHint" xmlns:sys="clr-namespace:System;assembly=mscorlib">Windows uses detected local adapters such as Wi-Fi, hotspot, Ethernet, PdaNet, and similar bridges for discovery. GPS location is not required on the desktop side.</sys:String>
    <sys:String x:Key="TrustedDevicesLabel" xmlns:sys="clr-namespace:System;assembly=mscorlib">Trusted devices:</sys:String>
