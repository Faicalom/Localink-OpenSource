<UserControl x:Class="LocalBridge.Desktop.Ui.Widgets.ConnectionStatusWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
            <TextBlock Text="{DynamicResource ConnectionOverviewTitle}"
                       Style="{StaticResource SectionTitleTextBlockStyle}" />
            <TextBlock Margin="0,8,0,0"
                       Style="{StaticResource SectionSubtitleTextBlockStyle}"
                       Text="{Binding TransportHint}" />

            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource MetricTileBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StateLabel}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding LifecycleState}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource MetricTileBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ModeLabel}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MetricValueTextBlockStyle}"
                                   Text="{Binding CurrentMode}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Margin="0,16,0,0"
                    Style="{StaticResource InsetCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{StaticResource AccentBrush}"
                               FontWeight="SemiBold"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="{Binding ActivePeerName, StringFormat=الجهاز النشط: {0}}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
