<UserControl x:Class="LocalBridge.Desktop.Ui.Widgets.ChatTransferBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LocalBridge.Desktop.Ui.Converters"
             xmlns:models="clr-namespace:LocalBridge.Desktop.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:ImageThumbnailConverter x:Key="ImageThumbnailConverter" />
    </UserControl.Resources>

    <Grid Margin="0,0,0,14"
          HorizontalAlignment="Left">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                        <Setter Property="HorizontalAlignment" Value="Right" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Border MaxWidth="600"
                Padding="16,14"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="22">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource SurfaceBackgroundBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Text="{Binding DirectionLabel}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                                    <Setter Property="Foreground" Value="#08111F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="0,2,0,0"
                           Foreground="{StaticResource AccentSoftBrush}"
                           Text="{DynamicResource AttachmentSuffix}" />

                <TextBlock Margin="0,4,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding PeerName, StringFormat=Peer: {0}}" />

                <Border Height="132"
                        Margin="0,10,0,0"
                        Background="{StaticResource SurfaceBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        ClipToBounds="True">
                    <Grid>
                        <Image Stretch="UniformToFill"
                               Source="{Binding PreviewPath, Converter={StaticResource ImageThumbnailConverter}}">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsImagePreviewAvailable}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>

                        <Border Background="{StaticResource SurfaceBackgroundBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsImagePreviewAvailable}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding PreviewFallbackLabel}" />
                                <TextBlock Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Text="{Binding MimeType}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Margin="0,10,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding FileName}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                                    <Setter Property="Foreground" Value="#08111F" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0">
                          <TextBlock FontSize="18"
                                     FlowDirection="LeftToRight"
                                     FontWeight="Bold"
                                     Text="{Binding TransferRateLabel}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                                            <Setter Property="Foreground" Value="#08111F" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding TransferTelemetryLabel}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                                            <Setter Property="Foreground" Value="#163746" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="{Binding StatusLabel}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource AccentSoftBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Direction}" Value="{x:Static models:TransferDirection.Outgoing}">
                                        <Setter Property="Foreground" Value="#163746" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="{Binding SizeLabel}" />

                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                FlowDirection="LeftToRight"
                                Text="{Binding SpeedLabel}" />
                      <TextBlock Grid.Column="1"
                                 HorizontalAlignment="Right"
                                 Foreground="{StaticResource MutedTextBrush}"
                                 FlowDirection="LeftToRight"
                                 Text="{Binding EtaLabel}" />
                </Grid>

                <DockPanel Margin="0,10,0,0">
                    <TextBlock DockPanel.Dock="Left"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               Text="{Binding CreatedAtLabel}" />

                    <Button DockPanel.Dock="Right"
                            Padding="10,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenTransferCommand, ElementName=Root}"
                            CommandParameter="{Binding}"
                            Content="{DynamicResource OpenButton}"
                            IsEnabled="{Binding CanOpen}" />
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
